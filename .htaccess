RewriteEngine On

# 1. Redirect index.html to Root (External Redirect)
RewriteCond %{THE_REQUEST} /index\.html [NC]
RewriteRule ^(.*)index\.html$ /$1 [L,R=301]

# 2. Map /home to Root (Internal)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^home$ / [L]

# 3. Handle pamban Ghost Redirect (Folder logic)
# (Your Pamban page uses JS for fine-tuning the URL bar)
# If pamban.html exists, treat as clean
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^(.*)$ $1.html [L]
